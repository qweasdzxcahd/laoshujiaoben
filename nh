local function getSortedNPCs()
    local hrp = getHrp()
    if not hrp then return {} end
    local t = {}
    for _, npc in next, monsters:GetChildren() do
        local hum = npc:FindFirstChildOfClass("Humanoid")
        local nhrp = npc:FindFirstChild("HumanoidRootPart")
        if hum and hum.Health > 0 and nhrp then
            table.insert(t, {npc = npc, dist = (nhrp.Position - hrp.Position).Magnitude})
        end
    end
    table.sort(t, function(a, b) return a.dist < b.dist end)
    return t
end

task.spawn(function()
    while task.wait(0.01) do
        if cfg.enabled then
            local sorted = getSortedNPCs()
            for _, entry in next, sorted do
                local npc = entry.npc
                local id = npc:GetFullName()
                local hum = npc:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 and not attacked[id] then
                    attacked[id] = true
                    task.spawn(function()
                        while cfg.enabled and npc.Parent and hum and hum.Health > 0 do
                            fireNPC(npc)
                            task.wait(0.02)
                        end
                        attacked[id] = nil
                    end)
                end
            end
        end
    end
end)

uis.InputBegan:Connect(function(k,g)
    if g then return end
    if k.KeyCode == Enum.KeyCode.RightShift then
        sg.Enabled = not sg.Enabled
    end
end)
