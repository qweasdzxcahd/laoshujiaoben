local bloodFx = miscs.GunVisualEffects.Common.BloodEffect
local muzzleFx = miscs.GunVisualEffects.Common.MuzzleEffect
local explodeFx = miscs.GunVisualEffects.Common.ExplosionEffect

local cfg = { enabled = false, shootId = 0 }
