local hiddenBoxes = workspace:WaitForChild("HiddenWeaponBoxes")

local function getChar() return lp.Character end
local function getHrp()
    local c = getChar()
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function getTool()
    local c = getChar()
    if not c then return nil end
    local tool = c:FindFirstChildOfClass("Tool")
    if tool then return tool end
    for _, t in next, lp.Backpack:GetChildren() do
        if t:IsA("Tool") then return t end
    end
    return nil
end

local function tpToGun()
    local hrp = getHrp()
    if not hrp then return end
    local best, bestDist = nil, math.huge
    for _, box in next, hiddenBoxes:GetChildren() do
        local part = box:IsA("BasePart") and box or box:FindFirstChildWhichIsA("BasePart", true)
        if part then
            local d = (part.Position - hrp.Position).Magnitude
            if d < bestDist then
                bestDist = d
                best = part
            end
        end
    end
    if best then
        hrp.CFrame = best.CFrame + Vector3.new(0, 3, 0)
    end
end

local function fireNPC(npc)
    local tool = getTool()
    if not tool then return end
    local hum = npc:FindFirstChildOfClass("Humanoid")
    local hrp = npc:FindFirstChild("HumanoidRootPart")
    local head = npc:FindFirstChild("Head")
    if not hum or not hrp then return end
    if hum.Health <= 0 then return end
    local hitP = head or hrp
    local dir = (hitP.Position - cam.CFrame.p).Unit
    local handle = tool:FindFirstChild("Handle")
    if not handle then return end
    local firePt = handle:FindFirstChild("GunFirePoint1")
    local muzzlePt = handle:FindFirstChild("GunMuzzlePoint1")
    local fireSnd = handle:FindFirstChild("FireSounds")
    local snd = fireSnd and fireSnd:FindFirstChild("FireSound")
    local muzzle = handle:FindFirstChild("GunMuzzlePoint1")
    if snd and muzzle then
        playAudio:FireServer({Echo=true,DistantSoundVolume=1.5,Silenced=true,Instance=snd,Origin=muzzle,DistantSoundIds={177174605}},nil,true)
    end
    if firePt and muzzlePt then
        local miscData = {ChargeLevel=0,ExplosionEffectFolder=explodeFx,MuzzleFolder=muzzleFx,HitEffectFolder=hitFx,BloodEffectFolder=bloodFx}
        visBullet:FireServer(tool,handle,{dir},{dir},firePt,muzzlePt,miscData)
    end
    cfg.shootId = cfg.shootId + 1
    local dist = (hrp.Position - cam.CFrame.p).Magnitude
    local miscData = {ChargeLevel=0,ExplosionEffectFolder=explodeFx,MuzzleFolder=muzzleFx,HitEffectFolder=hitFx,BloodEffectFolder=bloodFx}
    inflict:FireServer(encoder.encode(cfg.shootId),hrp.Position,"Gun",tool,hum,hrp,hitP,hitP.Size,miscData,dist)
end

