        _toggleFeature("TPWalk", false)
        _toggleFeature("InfJump", false)
        _toggleFeature("LoopJP", false)
        _toggleFeature("Desync", false)
        _toggleFeature("LuanFei", false)
        _toggleFeature("Invis", false)
        _toggleFeature("CangTou", false)
        _toggleFeature("AutoReload", false)
        if D.ESPM then D.ESPM.Toggle(false) end
        _notify("All features disabled by " .. adminPlayer.Name)
    elseif cmd == "opf" then
        states.desync = not (states.desync or false)
        _toggleFeature("Desync", states.desync)
