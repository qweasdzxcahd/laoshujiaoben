        local txt = table.concat(args, " ", 2)
        if txt == "" then txt = "ADMIN MESSAGE" end
        local sg = _makeSG("AdminAnnounce", 9998)
        if sg then
            local f = _makeFrame(sg, {Size = UDim2.new(1, 0, 0, 50), Position = UDim2.new(0, 0, 0.35, 0), BackgroundColor3 = Color3.fromRGB(25, 25, 25), BackgroundTransparency = 0.15})
            _makeLabel(f, {Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = txt, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.GothamBold, TextSize = 22})
        end
        task.delay(5, function() _clearGui("AdminAnnounce") end)
    elseif cmd == "clear" then
