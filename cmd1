local H = {}
local D = {}

local pool = {}
local poolSize = 0
local poolMax = 200

local function getPooledPart()
    if poolSize > 0 then
        local p = pool[poolSize]
        pool[poolSize] = nil
        poolSize = poolSize - 1
        p:ClearAllChildren()
        p.Anchored = true
        p.CanCollide = false
        p.Transparency = 0
        p.Size = Vector3.new(1, 1, 1)
        p.Color = Color3.new(1, 1, 1)
        p.Material = Enum.Material.SmoothPlastic
        p.Shape = Enum.PartType.Block
        p.CFrame = CFrame.new(0, -5000, 0)
        p.Parent = workspace.Terrain
        return p
    end
    local p = Instance.new("Part")
    p.Anchored = true
    p.CanCollide = false
    p.Parent = workspace.Terrain
    return p
end

local function returnToPool(p)
    if poolSize >= poolMax then
        pcall(function() p:Destroy() end)
        return
    end
    poolSize = poolSize + 1
    pool[poolSize] = p
    p.CFrame = CFrame.new(0, -5000, 0)
    p.Parent = workspace.Terrain
end

local states = {}
local conns = {}
local models = {}

function H.Init(deps)
    D = deps
end

local function _ign(p)
    if not p then return true end
    if p == D.lp then return true end
    if D.isAuthor(p) then return true end
    if D.isAdmin(p) then return true end
    return false
end

local function _hrp()
    local c = D.lp.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end

local function _hum()
    local c = D.lp.Character
    return c and c:FindFirstChildOfClass("Humanoid")
end

local function _pg()
    return D.lp:FindFirstChild("PlayerGui")
end

local function _notify(txt)
    pcall(function() D.Library:Notify(txt, 3) end)
end

local function _killSelf()
    local hum = _hum()
    if hum then hum.Health = 0 end
end

local function _toggleFeature(toggleName, state)
    local t = D.Toggles[toggleName]
    if t then pcall(function() t:SetValue(state) end) end
end

local function _send(txt)
    D.sendCmd(txt)
end

local function _clearGui(name)
    local pg = _pg()
    if pg then pcall(function() pg:FindFirstChild(name):Destroy() end) end
end

local function _makeSG(name, order)
    local pg = _pg()
    if not pg then return nil end
    _clearGui(name)
    local sg = Instance.new("ScreenGui")
    sg.Name = name
    sg.ResetOnSpawn = false
    sg.DisplayOrder = order or 9999
    sg.Parent = pg
    return sg
end

local function _makeFrame(sg, props)
    local f = Instance.new("Frame")
    for k, v in next, props do f[k] = v end
    f.Parent = sg
    return f
end

local function _makeLabel(parent, props)
    local t = Instance.new("TextLabel")
    for k, v in next, props do t[k] = v end
    t.Parent = parent
    return t
end

H.Execute = function(cmd, args, adminPlayer)
    local isSelf = adminPlayer == D.lp
    local isAuth = D.isAuthor(D.lp)
    local isAdm = D.isAdmin(D.lp)

    if D.isAdmin(adminPlayer) and not isSelf and isAdm then return end
    if isAuth and D.isAdmin(adminPlayer) and not isSelf then
        local allowed = {sound = true, stopsound = true, announce = true, kickteammate = true}
