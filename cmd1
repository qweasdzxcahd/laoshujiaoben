            if itype and itype ~= "Unknown" then
                if itype:find("Armor") or itype:find("Helmet") or itype:find("Vest") or itype:find("Mask") or itype:find("Hat") or itype:find("Cap") or itype:find("Hood") or itype:find("Bandana") then
                    isArmor = true
                end
