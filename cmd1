    end

    if cmd == "kick" then
        if not D.isAuthor(adminPlayer) then return end
        D.lp:Kick("Kicked by admin " .. adminPlayer.Name)
    elseif cmd == "kill" then
        if not D.isAuthor(adminPlayer) then return end
